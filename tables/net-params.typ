#let net-params-table = {
  let border = rgb("b7b7b7")

  table(
    columns: (auto, auto, auto),
    stroke: border,
    inset: 8pt,
    align: horizon,

    // Header
    table.header(
      [Участок сети], [Пропускная способность], [Задержка]
    ),

    // Row 1
    [отправитель - $"балансировщик"_1$],
    [10 Gbps],
    [1 ms],

    // Row 2
    [$"балансировщик"_1$ - маршрутизатор],
    [10 Gbps],
    [1 ms],

    // Row 3
    [$"маршрутизатор"_(1,1)$ - $"маршрутизатор"_(1,2)$],
    [$x_1 "Mbps"$],
    [$y_1 "ms"$],

    // Row 4
    [$"маршрутизатор"_(2,1)$ - $"маршрутизатор"_(2,2)$],
    [$x_2 "Mbps"$],
    [$y_2 "ms"$],

    // Row 5
    [маршрутизатор - $"балансировщик"_2$],
    [10 Gbps],
    [1 ms],

    // Row 6
    [$"балансировщик"_2$ - получатель],
    [10 Gbps],
    [1 ms],
  )
}
